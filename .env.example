# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://dukadesk:dukadesk@localhost:5432/dukadesk

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Auth
OTP_EXPIRATION=5

# Storage (S3-compatible)
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=dukadesk
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# CORS
CORS_ORIGINS=*

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Apple Sign-In
APPLE_CLIENT_ID=your-apple-service-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey.p8
APPLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/apple/callback

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Payment Providers
PAYSTACK_SECRET_KEY=sk_test_placeholder
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder

# Notifications
EMAIL_PROVIDER=log
EMAIL_API_KEY=
EMAIL_FROM_NAME=DUKADESK
EMAIL_FROM_EMAIL=noreply@dukadesk.app
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

PUSH_PROVIDER=log
FCM_SERVER_KEY=

SMS_PROVIDER=log
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM=DUKADESK

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
