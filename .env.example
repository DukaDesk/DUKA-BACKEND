# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://dukadesk:dukadesk@localhost:5432/dukadesk

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Auth
OTP_EXPIRATION=5

# Storage (S3-compatible)
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=dukadesk
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# CORS
CORS_ORIGINS=*

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
